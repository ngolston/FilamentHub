# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-in-production

# ── App settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Storage paths (optional overrides) ───────────────────────────────────────
# DATABASE_URL=sqlite+aiosqlite:////app/data/filamenthub.db
# DATA_DIR=/app/data

# ── Optional: Discord webhook for alerts ─────────────────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Optional: SMTP for email (password reset, alerts) ────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=app-password
# EMAILS_FROM=noreply@filamenthub.local
