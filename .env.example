# ─────────────────────────────────────────────────────────────────────────────
# FilamentHub — environment variables
#
# Copy this file to .env and fill in the values before starting the app.
#
# Self-host quick start:
#   cp .env.example .env
#   # Set SECRET_KEY below (required):
#   openssl rand -hex 32
#   docker compose -f docker-compose.selfhost.yml up -d
# ─────────────────────────────────────────────────────────────────────────────


# ── Self-host settings ────────────────────────────────────────────────────────

# Public URL of your FilamentHub instance (no trailing slash).
# Used to build password-reset and email-verify links, and for CORS.
#   LAN example:  http://192.168.1.100
#   Domain:       https://filamenthub.yourdomain.com
FRONTEND_URL=http://localhost

# Port to expose on the host machine (default: 80)
PORT=80


# ── App ───────────────────────────────────────────────────────────────────────

APP_NAME=FilamentHub
ENVIRONMENT=development
DEBUG=false


# ── Security ──────────────────────────────────────────────────────────────────

# REQUIRED in production — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30


# ── Database ──────────────────────────────────────────────────────────────────

# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./data/filamenthub.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/filamenthub


# ── Frontend ──────────────────────────────────────────────────────────────────

# Base URL of the frontend — used to build password-reset and email-verify links
FRONTEND_URL=http://localhost:5173

# Production example:
# FRONTEND_URL=https://app.filamenthub.example.com


# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Production example:
# CORS_ORIGINS=https://app.filamenthub.example.com


# ── Data / media storage ──────────────────────────────────────────────────────

DATA_DIR=./data


# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Optional. If omitted, emails are printed to the console (dev mode).
# Required for password reset and email verification in production.

# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# EMAILS_FROM=noreply@filamenthub.example.com

# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password


# ── Integrations ──────────────────────────────────────────────────────────────

# Discord webhook URL for low-stock alert notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
